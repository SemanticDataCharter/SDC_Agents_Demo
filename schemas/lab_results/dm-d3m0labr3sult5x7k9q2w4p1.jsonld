        "sdc4-meta:isConstrainedByRmComponent": {"@id": "sdc4:XdStringType"},
        "rdfs:label": "Units",
        "rdfs:comment": "Unit of measure for the test result."
      },
      {
        "@id": "sdc4:mc-lr05c0ll3ct10nd4t3t3mp0r",
