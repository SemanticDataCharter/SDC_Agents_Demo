    "@type": "sdc4-meta:ModelComponent",
    "sdc4-meta:isConstrainedByRmComponent": {"@id": "sdc4:ClusterType"},
    "rdfs:label": "SensorReadings Data Cluster",
    "sdc4-meta:hasComponent": [
      {
        "@id": "sdc4:mc-sr01s3ns0r1dstr1ngv4lu3ab",
        "@type": "sdc4-meta:ModelComponent",
        "sdc4-meta:isConstrainedByRmComponent": {"@id": "sdc4:XdStringType"},
        "rdfs:label": "Sensor ID",
