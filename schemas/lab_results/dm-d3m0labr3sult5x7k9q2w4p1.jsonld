        "@type": "sdc4-meta:ModelComponent",
        "sdc4-meta:isConstrainedByRmComponent": {"@id": "sdc4:XdQuantityType"},
        "rdfs:label": "Result Value",
        "rdfs:comment": "Quantitative result of the laboratory test with associated units of measure."
      },
      {
        "@id": "sdc4:mc-lr04un1t5str1ngv4lu3c0lx",
