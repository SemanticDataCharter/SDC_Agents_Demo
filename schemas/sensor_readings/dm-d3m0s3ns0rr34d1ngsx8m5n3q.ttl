@prefix rdf:       <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:       <http://www.w3.org/2002/07/owl#> .
@prefix xsd:       <http://www.w3.org/2001/XMLSchema#> .
@prefix dc:        <http://purl.org/dc/elements/1.1/> .
@prefix sdc4:      <https://semanticdatacharter.com/ns/sdc4/> .
@prefix sdc4-meta: <https://semanticdatacharter.com/ontology/sdc4-meta/> .

# =============================================================================
# Data Model: SensorReadings
# =============================================================================

sdc4:dm-d3m0s3ns0rr34d1ngsx8m5n3q
    a sdc4-meta:DataModel ;
    rdfs:label "SensorReadings" ;
    dc:title "SensorReadings" ;
    dc:creator "SDC Agents Demo" ;
    dc:subject "Environmental sensor readings" ;
    dc:description "Data model for environmental sensor readings including sensor identification, location path, temperature and humidity measurements, reading timestamps, and operational status." ;
    dc:date "2025-11-01" ;
    dc:language "en-US" ;
    sdc4-meta:hasCluster sdc4:mc-sr00clust3rs3ns0rr34d1ngs .

# Cluster
sdc4:mc-sr00clust3rs3ns0rr34d1ngs
    a sdc4-meta:ModelComponent ;
    sdc4-meta:isConstrainedByRmComponent sdc4:ClusterType ;
    rdfs:label "SensorReadings Data Cluster" ;
    sdc4-meta:hasComponent sdc4:mc-sr01s3ns0r1dstr1ngv4lu3ab ,
                           sdc4:mc-sr02l0c4t10nstr1ngv4lu3cd ,
                           sdc4:mc-sr03t3mp3r4tur3qu4nt1ty3f ,
                           sdc4:mc-sr04hum1d1tyqu4nt1tyv4lu3g ,
                           sdc4:mc-sr05r34d1ngt1m3t3mp0r4lhi ,
                           sdc4:mc-sr06st4tusstr1ngv4lu3x7kjl .

# Sensor ID (XdString)
sdc4:mc-sr01s3ns0r1dstr1ngv4lu3ab
    a sdc4-meta:ModelComponent ;
    sdc4-meta:isConstrainedByRmComponent sdc4:XdStringType ;
    rdfs:label "Sensor ID" ;
    rdfs:comment "Unique sensor identifier (e.g. SNS-A001)." .

# Location (XdString)
sdc4:mc-sr02l0c4t10nstr1ngv4lu3cd
    a sdc4-meta:ModelComponent ;
    sdc4-meta:isConstrainedByRmComponent sdc4:XdStringType ;
    rdfs:label "Location" ;
    rdfs:comment "Hierarchical location path (Building/Floor/Room)." .

# Temperature (XdQuantity)
sdc4:mc-sr03t3mp3r4tur3qu4nt1ty3f
    a sdc4-meta:ModelComponent ;
    sdc4-meta:isConstrainedByRmComponent sdc4:XdQuantityType ;
    rdfs:label "Temperature" ;
    rdfs:comment "Temperature reading in degrees Celsius." .

# Humidity (XdQuantity)
sdc4:mc-sr04hum1d1tyqu4nt1tyv4lu3g
    a sdc4-meta:ModelComponent ;
    sdc4-meta:isConstrainedByRmComponent sdc4:XdQuantityType ;
    rdfs:label "Humidity" ;
    rdfs:comment "Relative humidity percentage." .

# Reading Time (XdTemporal)
sdc4:mc-sr05r34d1ngt1m3t3mp0r4lhi
    a sdc4-meta:ModelComponent ;
    sdc4-meta:isConstrainedByRmComponent sdc4:XdTemporalType ;
    rdfs:label "Reading Time" ;
    rdfs:comment "ISO 8601 timestamp of the sensor reading." .

# Status (XdString)
sdc4:mc-sr06st4tusstr1ngv4lu3x7kjl
    a sdc4-meta:ModelComponent ;
    sdc4-meta:isConstrainedByRmComponent sdc4:XdStringType ;
    rdfs:label "Status" ;
    rdfs:comment "Operational status (normal, warning, critical)." .
